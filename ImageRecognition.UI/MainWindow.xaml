<Window x:Class="ImageRecognition.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Image Recognition: kNN + KD-Tree"
        Height="760" Width="1120"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="#111827"
                   Text="Система распознавания изображений (kNN + KD-Tree)"/>

        <TabControl Grid.Row="1" Margin="0,12,0,0">
            <TabItem Header="Подключение к БД">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Host"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,12,8" x:Name="DbHostTextBox" Text="localhost"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="Port"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" x:Name="DbPortTextBox" Text="5432"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Database"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,8" x:Name="DbNameTextBox" Text="Image_recognition_db"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="Username"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" x:Name="DbUserTextBox" Text="postgres"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Password"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,12,8" x:Name="DbPasswordTextBox" Text="10112275"/>

                    <WrapPanel Grid.Row="3" Grid.ColumnSpan="4" Margin="0,6,0,0">
                        <Button x:Name="ConnectDbButton" Width="180" Margin="0,0,8,0" Content="Подключиться к БД" Click="ConnectDbButton_Click"/>
                        <Button x:Name="InitializeSchemaButton" Width="210" Margin="0,0,8,0" Content="Инициализировать таблицы" Click="InitializeDatabaseButton_Click"/>
                        <Button Width="180" Margin="0,0,8,0" Content="Проверить записи в БД" Click="CheckDatabaseButton_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Работа с моделью">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="10" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,8,0">
                        <StackPanel x:Name="WorkPanel">
                            <TextBlock FontWeight="Bold" FontSize="16" Text="Добавление обучающего примера"/>
                            <TextBlock Margin="0,10,0,2" Text="Правильный класс (например, digit_5)"/>
                            <TextBox x:Name="ClassNameTextBox" Text="digit_5"/>
                            <TextBlock Margin="0,8,0,2" Text="Фото для обучения"/>
                            <DockPanel>
                                <TextBox x:Name="TrainingImagePathTextBox" DockPanel.Dock="Left"/>
                                <Button Content="Выбрать..." Click="BrowseTrainingImageButton_Click"/>
                            </DockPanel>
                            <Button Margin="0,8,0,0" Width="260" Content="Сохранить пример в БД" Click="AddTrainingImageButton_Click"/>
                            <Button x:Name="GenerateDemoButton" Margin="0,8,0,0" Width="280" Content="Сгенерировать демо-примеры и загрузить" Click="GenerateDemoSamplesButton_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="10" BorderBrush="#D1D5DB" BorderThickness="1" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="16" Text="Обучение и распознавание"/>
                            <TextBlock Margin="0,10,0,2" Text="Название модели"/>
                            <TextBox x:Name="ModelNameTextBox" Text="kNN_coursework_model"/>
                            <TextBlock Margin="0,8,0,2" Text="k (положительное целое)"/>
                            <TextBox x:Name="KTextBox" Text="3"/>
                            <TextBlock Margin="0,8,0,2" Text="Фото для определения"/>
                            <DockPanel>
                                <TextBox x:Name="InferenceImagePathTextBox" DockPanel.Dock="Left"/>
                                <Button Content="Выбрать..." Click="BrowseInferenceImageButton_Click"/>
                            </DockPanel>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Width="150" Margin="0,0,8,8" Content="Обучить модель" Click="TrainModelButton_Click"/>
                                <Button Width="220" Margin="0,0,8,8" Content="Определить, что на фото (KD-Tree)" Click="ClassifyKdTreeButton_Click"/>
                                <Button Width="220" Margin="0,0,8,8" Content="Определить, что на фото (линейно)" Click="ClassifyLinearButton_Click"/>
                                <Button Width="150" Margin="0,0,8,8" Content="Запустить benchmark" Click="BenchmarkButton_Click"/>
                            </WrapPanel>

                            <Border Margin="0,10,0,0" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="Последний результат"/>
                                    <TextBlock x:Name="LastResultTextBlock" Margin="0,6,0,0" Text="Нет данных"/>
                                    <TextBlock x:Name="ConnectionStatusTextBlock" Margin="0,8,0,0" Foreground="#991B1B" Text="БД: не подключено"/>
                                    <TextBlock x:Name="DatabaseStatsTextBlock" Margin="0,6,0,0" Text="Статистика БД: нет данных"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Справка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Margin="12" TextWrapping="Wrap" FontSize="14">
Быстрый старт:
1) Вкладка "Подключение к БД" → введите параметры → "Подключиться к БД".
2) Нажмите "Инициализировать таблицы".
3) Нажмите "Проверить записи в БД" и убедитесь, что есть соединение.
4) Вкладка "Работа с моделью":
   - добавьте обучающие примеры вручную ИЛИ нажмите кнопку генерации демо-примеров;
   - нажмите "Обучить модель";
   - выберите фото для определения;
   - нажмите "Определить, что на фото".

Как понимать результат:
- Если в блоке "Последний результат" написано "Класс: digit_5",
  значит модель считает, что на изображении цифра 5.
- Если результат неверный, причина чаще всего в обучающих данных:
  мало примеров или неверные метки классов.

Важные советы:
- Не смешивайте классы: цифру 7 нельзя добавлять как digit_5.
- Для каждого класса добавляйте несколько разных изображений.
- После добавления новых данных всегда переобучайте модель.
- Загруженные обучающие изображения сохраняются прямо в PostgreSQL в формате BYTEA.
                    </TextBlock>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" BorderBrush="#D1D5DB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="16" Text="Лог выполнения"/>
                <TextBox Grid.Row="1" x:Name="LogTextBox" Margin="0,8,0,0" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         FontFamily="Consolas" Background="#0F172A" Foreground="#E5E7EB"/>
            </Grid>
        </Border>
    </Grid>
</Window>
